{
  "name": "overwatch-control",
  "productName": "Overwatch Control",
  "version": "0.1.0",
  "private": true,
  "description": "Overwatch Command Workstation — Autonomous Perching Drone Mesh Control",
  "main": ".vite/build/main.js",
  "scripts": {
    "start": "electron-forge start",
    "dev": "electron-forge start",
    "package": "electron-forge package",
