    "postinstall": "/usr/libexec/PlistBuddy -c 'Set :CFBundleName Overwatch Control' node_modules/electron/dist/Electron.app/Contents/Info.plist && /usr/libexec/PlistBuddy -c 'Set :CFBundleDisplayName Overwatch Control' node_modules/electron/dist/Electron.app/Contents/Info.plist || true"
  },
