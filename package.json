    "clsx": "^2.1.1",
    "electron-squirrel-startup": "^1.0.1",
    "lucide-react": "^0.575.0",
    "maplibre-gl": "^5.18.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-map-gl": "^8.1.0",
    "recharts": "^3.7.0",
    "sqlite-vec": "^0.1.7-alpha.2",
    "tailwindcss": "^4.2.0",
    "ws": "^8.18.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.8.0",
