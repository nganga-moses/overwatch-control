    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.0",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^35.0.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  }
